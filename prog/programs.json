{
    "os" : {
        "Darwin" : {
            "program" : "brew",
            "args" : [ "install" ]
        },
        "Fedora" : {
            "program" : "dnf",
            "args" : [ "install", "-y" ]
        },
        "Gentoo" : {
            "program" : "emerge",
            "args" : [ "--ask" ]
        },
        "Debian" : {
            "program" : "apt",
            "args" : [ "install", "-y"]
        }
    },
    "programs" : [
        {
            "Gentoo" : "dev-vcs/git",
            "default" : "git"
        },
        {
            "Gentoo" : "app-editors/neovim",
            "default" : "neovim"
        },
        {
            "Gentoo" : "app-misc/tmux",
            "default" : "tmux"
        },
        {
            "Gentoo" : "app-shells/fzf",
            "default" : "fzf"
        },
        {
            "Gentoo" : "app-shells/zsh",
            "default" : "zsh"
        },
        {
            "Gentoo" : "kde-plasma/plasma-meta"
        },
        {
            "Gentoo" : "kde-apps/kdecore-meta"
        },
        {
            "Gentoo" : "x11-wm/windowmaker"
        },
        {
            "Gentoo" : "x11-themes/windowmaker-themes"
        },
        {
            "Gentoo" : "www-client/firefox"
        },
        {
            "Gentoo" : "sys-fs/xfsdump"
        },
        {
            "Gentoo" : "x11-terms/ghostty"
        },
        {
            "Gentoo" : "sys-process/htop",
            "default" : "htop"
        },
        {
            "Gentoo" : "sys-process/btop",
            "default" : "btop"
        },
        {
            "Gentoo" : "dev-lang/go",
            "Fedora" : "golang",
            "default" : "go"
        },
        {
            "Fedora" : "@development-tools",
            "Debian" : "build-essential"
        },
        {
            "default" : "gdb"
        },
        {
            "Fedora" : "clangd"
        }
    ],
    "vcs" : {
        "git" : {
            "program" : "git",
            "args": [ "clone" ]
        },
        "wget" : {
            "program" : "wget",
            "args" : []
        }
    },
    "sources" : [
        {
            "type" : "git",
            "target" : "$HOME/personal",
            "repo" : "https://github.com/9fans/plan9port.git",
            "dir" : "plan9port",
            "command" : {
                "program" : "./INSTALL",
                "args": []
            }
        },
        {
            "type" : "wget",
            "target" : "$HOME/personal/bin",
            "repo" : "https://fennel-lang.org/downloads/fennel-1.6.1",
            "dir" : "$HOME/personal/bin",
            "command" : {
                "program" : "chmod",
                "args" : ["+x", "fennel-1.6.1"]
            }
        }
    ]
}
